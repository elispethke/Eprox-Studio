# Server-only endpoint the contact route handler (app/api/contact) forwards
# submissions to. Create a form at https://formspree.io and paste its URL in
# .env.local. NEVER prefix this with NEXT_PUBLIC_ — that would embed the
# value in the client bundle and defeat the whole point of the relay.
FORMSPREE_ENDPOINT=
NEXT_PUBLIC_SITE_URL=

# Optional — analytics embed loaded ONLY after the visitor accepts cookies
# (e.g. Plausible/Umami script URL). Leave empty to ship zero analytics.
NEXT_PUBLIC_ANALYTICS_SRC=

# Optional — Upstash Redis pair enables distributed rate limiting for the
# contact relay across serverless instances. Falls back to in-memory if unset.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional — error-tracking DSN consumed by src/instrumentation.ts once an
# APM SDK is wired in.
SENTRY_DSN=
